class Solution {
    public int[] maxSlidingWindow(int[] nums, int k) {
        int n = nums.length;

        Deque<Integer> dq  = new ArrayDeque<>();
        int[] arr = new int[n-k+1];

        for(int i=0;i<n;i++){

            if(! dq.isEmpty() && dq.peekFirst() <=i-k){
                dq.removeFirst();
            }

            while(! dq.isEmpty() && nums[dq.peekLast()] <=nums[i]){
                dq.removeLast();
            }
            dq.addLast(i);

            if(i>=k-1){
                arr[i-k+1] = nums[dq.peekFirst()];
            }

        }
        return arr;
    }
}
