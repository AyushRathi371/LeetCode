class Solution {
    public String removeKdigits(String num, int k) {
        StringBuilder sb  = new StringBuilder();
        Stack<Character> st  = new Stack<>();
        int n = num.length();

        if(k >=n){
            return "0";
        }

        for(char ch : num.toCharArray()){
            
            while(!st.isEmpty() &&st.peek() > ch && k>0){
                st.pop();
                k--;
            }
            st.push(ch);
        }
        while(k>0){
            st.pop();
            k--;
        }

        while(!st.isEmpty()){
            sb.append(st.pop());
        }

        sb.reverse();

        while(sb.length() >1 && sb.charAt(0) == '0'){
            sb.deleteCharAt(0);
        }

        return sb.toString();
    }
}
