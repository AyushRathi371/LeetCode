class LRUCache {
    class Node{
    int key;
    int val;
    Node next;
    Node prev;
    Node(int key,int val){
        this.key = key;
        this.val = val;
        this.next = null;
        this.prev = null;
    }
}
    int capacity;
    Node head = new Node(-1,-1);
    Node tail = new Node(-1,-1);
    HashMap<Integer,Node> map = new HashMap<>();

    
    public void deleteTail(Node node){
        Node first = node.prev;
        Node second = node.next;

        first.next = second;
        second.prev = first;
    }

    public void insertHead(Node node){
        Node second  = head.next;

        head.next = node;
        node.prev =head;

        node.next = second;
        second.prev = node;
    }

    public LRUCache(int capacity) {
        this.capacity = capacity;
        map.clear();
        head.next = tail;
        tail.prev = head;

    }
    
    public int get(int key) {
        if(map.containsKey(key)){
            Node node = map.get(key);
            
            deleteTail(node);
            insertHead(node);

            return node.val;

        }
        return -1;
    }
    
    public void put(int key, int value) {
        if(map.containsKey(key)){
            Node node = map.get(key);
            node.val = value;
            
            deleteTail(node);
            insertHead(node);
            return;
        }

        if(map.size() == capacity){
            Node node  = tail.prev;

            map.remove(node.key);
            deleteTail(node);
        }

        Node node = new Node(key,value);
        map.put(key,node);
        insertHead(node);
    }
}

