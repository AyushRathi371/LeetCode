class Solution {
    public String minWindow(String s, String t) {
        int[] hash = new int[256];
        for(int i=0;i<t.length();i++){
            hash[t.charAt(i)]++;
        }
        int r=0,l=0,len = Integer.MAX_VALUE;
        int cnt =0,idx =-1;
        
        while(r<s.length()){
            if(hash[s.charAt(r)]>0)cnt++;
            hash[s.charAt(r)]--;

            while(cnt==t.length()){
                if(len >r-l+1){
                    len = r-l+1;
                    idx = l;
                }
                hash[s.charAt(l)]++;
                if(hash[s.charAt(l)]>0){
                    cnt--;
                }
                l++;
            }
            
            r++;
        }
        return idx == -1 ? "" :s.substring(idx,idx+len);
    }
}
