class Solution {
    public int trap(int[] height) {
        int n  = height.length;
        int sum =0;
        int porSum =0;
        int max =0;
        Stack<Integer> st = new Stack<>();
        int cnt =0;
        for(int i=0;i<n;i++){
            while(!st.isEmpty() && st.peek() <= height[i]){
                max = st.peek();
                porSum -= st.peek();
                st.pop();
                cnt++;
            }
            if(st.isEmpty()){
                porSum  += (cnt)*max;
                sum +=porSum;
                cnt =0;
                porSum =0;
            }
            st.push(height[i]);

        }
        if(!st.isEmpty()){
            int  i = n-1;
            cnt =0;
            porSum =0;
            while(!st.isEmpty() && i>=0){
                if(cnt !=0){
                    sum += (cnt*max) ;
                    sum += porSum;
                    porSum =0;
                    cnt =0;
                    
                }
                if(height[i]==st.peek()){
                    max = st.pop();
                    i--;
                }else if(height[i]<st.peek()){
                    cnt++;
                    porSum -=height[i];
                    i--;
                }
            }
        }
    return sum;
    }
}
